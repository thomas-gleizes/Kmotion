{
  "manifest_version": 3,
  "name": "kMotion - YouTube to MP3",
  "version": "1.0.0",
  "description": "Convert YouTube videos to MP3 with kMotion",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtu.be/*",
    "http://localhost:3000/*",
    "https://kmotion.thomasgleizes.fr/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kmotion@kmotion.app",
      "strict_min_version": "115.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "kMotion - YouTube to MP3"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtu.be/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
